# EDQ environment configuration
#
# Local engineer workflow:
#   1. Copy this file to .env, or run setup.sh / setup.bat
#   2. Replace any CHANGE_ME values if you created .env manually
#   3. Keep COOKIE_SECURE=false for http://localhost testing
#
# Production note:
#   Set COOKIE_SECURE=true and replace localhost values before any shared or
#   internet-facing deployment.

# Required secrets
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
SECRET_KEY=CHANGE_ME_SECRET_KEY
TOOLS_API_KEY=CHANGE_ME_TOOLS_API_KEY
INITIAL_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Local engineer defaults
COOKIE_SECURE=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/edq.db

# JWT token lifetimes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
# Local engineer testing works through the frontend at http://localhost.
# Replace these with your real domain(s) for shared or production deployments.
CORS_ORIGINS=["http://localhost","http://127.0.0.1"]

# File storage
UPLOAD_DIR=./uploads
REPORT_DIR=./reports

# Tools sidecar
TOOLS_SIDECAR_URL=http://tools:8001

# AI synopsis (optional)
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-4o

# Runtime
LOG_LEVEL=INFO
DEBUG=false
ALLOW_REGISTRATION=false

# Redis (optional, multi-instance deployments)
# REDIS_URL=redis://redis:6379/0

# OIDC / SSO (optional)
# OIDC_PROVIDER=google
# OIDC_CLIENT_ID=your-client-id.apps.googleusercontent.com
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_DISCOVERY_URL=
# OIDC_ALLOWED_DOMAINS=example.com

# Sentry (optional)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Audit log retention
# AUDIT_LOG_RETENTION_DAYS=365
