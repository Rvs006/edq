# EDQ Environment Configuration
# Electracom Device Qualifier — Electracom Projects Ltd
#
# Copy this file to .env and fill in ALL CHANGE_ME values before starting:
#   cp .env.example .env
#
# Generate secrets:
#   openssl rand -hex 64   (for JWT_SECRET, JWT_REFRESH_SECRET)
#   openssl rand -hex 32   (for SECRET_KEY, TOOLS_API_KEY)
#
# IMPORTANT: The app will REFUSE TO START if any CHANGE_ME values remain.

# ── SECURITY (REQUIRED — change ALL before first run) ────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
SECRET_KEY=CHANGE_ME_SECRET_KEY
TOOLS_API_KEY=CHANGE_ME_TOOLS_API_KEY
INITIAL_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── HTTPS (set true when behind TLS/reverse proxy) ───────────────
COOKIE_SECURE=true
# DOMAIN=edq.yourdomain.com

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/edq.db

# ── JWT Token Lifetimes ──────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS (update to your production domain) ──────────────────────
CORS_ORIGINS=["https://edq.yourdomain.com"]

# ── File Storage ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
REPORT_DIR=./reports

# ── Tools Sidecar (internal, set by docker-compose) ──────────────
TOOLS_SIDECAR_URL=http://tools:8001

# ── AI Synopsis (optional) ───────────────────────────────────────
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-4o

# ── Runtime ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
ALLOW_REGISTRATION=false

# ── Redis (optional — for multi-instance deployments) ────────────
# REDIS_URL=redis://redis:6379/0

# ── OIDC / SSO (optional — Google, Microsoft, Keycloak) ──────────
# OIDC_PROVIDER=google
# OIDC_CLIENT_ID=your-client-id.apps.googleusercontent.com
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_DISCOVERY_URL=                    (auto-set for google/microsoft)
# OIDC_ALLOWED_DOMAINS=electracom.com    (restrict by email domain)

# ── Sentry (optional — error tracking) ───────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Audit Log Retention ─────────────────────────────────────────
# AUDIT_LOG_RETENTION_DAYS=365
