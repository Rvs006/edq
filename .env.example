# EDQ Environment Configuration
# Electracom Device Qualifier — Electracom Projects Ltd
#
# Copy this file to .env and fill in the values.
# The Electron desktop app auto-generates .env from this file on first run.

# Security (REQUIRED — change these before first run)
JWT_SECRET=change-me-use-openssl-rand-hex-64
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Database (SQLite — no setup required)
DATABASE_URL=sqlite+aiosqlite:///./data/edq.db

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# File Storage
UPLOAD_DIR=./uploads
REPORT_DIR=./reports

# Tools Sidecar
TOOLS_SIDECAR_URL=http://tools:8001

# AI Synopsis (optional — configure with your preferred LLM provider)
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO
DEBUG=false
