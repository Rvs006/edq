# EDQ Environment Configuration
# Electracom Device Qualifier — Electracom Projects Ltd
#
# Copy this file to .env and fill in the values.
# The Electron desktop app auto-generates .env from this file on first run.

# Security (REQUIRED — change ALL of these before first run)
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-use-openssl-rand-hex-64
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-64
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32
# Set true when serving over HTTPS (required for production)
COOKIE_SECURE=false
# Initial admin password — set before first run, then change after first login
INITIAL_ADMIN_PASSWORD=change-me-strong-password
# Set false ONLY if your devices use self-signed certificates
SSL_VERIFY_DEVICES=true
# Set true to allow public self-registration (default: false — admin creates users)
ALLOW_REGISTRATION=false

# Database (SQLite — no setup required)
DATABASE_URL=sqlite+aiosqlite:///./data/edq.db

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# File Storage
UPLOAD_DIR=./uploads
REPORT_DIR=./reports

# Tools Sidecar
TOOLS_SIDECAR_URL=http://tools:8001

# AI Synopsis (optional — configure with your preferred LLM provider)
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO
DEBUG=false

# HTTPS (set COOKIE_SECURE=true and configure domain when using docker-compose.prod.yml)
# DOMAIN=edq.example.com
