# EDQ Environment Configuration
# Electracom Device Qualifier — Electracom Projects Ltd
#
# Copy this file to .env and fill in the values.
# The Electron desktop app auto-generates .env from this file on first run.

# Application
APP_NAME=EDQ
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database (SQLite — default for development)
DATABASE_URL=sqlite+aiosqlite:///./data/edq.db

# JWT Authentication
JWT_SECRET=change-me-jwt-secret-use-openssl-rand-hex-64
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# File Storage
UPLOAD_DIR=./uploads
REPORT_DIR=./reports

# AI Synopsis (optional — configure with your preferred LLM provider)
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-4o

# Tools Sidecar
TOOLS_SIDECAR_URL=http://host.docker.internal:8001

# Logging
LOG_LEVEL=INFO
