# EDQ environment configuration
#
# Local engineer workflow:
#   1. Copy this file to .env, or run setup.sh / setup.bat
#   2. Replace any CHANGE_ME values if you created .env manually
#   3. Keep COOKIE_SECURE=false for http://localhost testing
#
# Production note:
#   Set COOKIE_SECURE=true and replace localhost values before any shared or
#   internet-facing deployment.

# Required secrets
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
SECRET_KEY=CHANGE_ME_SECRET_KEY
TOOLS_API_KEY=CHANGE_ME_TOOLS_API_KEY
INITIAL_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Local engineer defaults
COOKIE_SECURE=false

# Database — PostgreSQL is the primary runtime for both direct and Docker runs.
# Direct local backend runs use 127.0.0.1; Docker overrides DB_HOST to "postgres".
DATABASE_URL=
DB_DRIVER=postgresql+asyncpg
DB_HOST=127.0.0.1
DB_PORT=55432
DB_NAME=edq
DB_USER=edq
DB_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DB_CONNECT_TIMEOUT_SECONDS=15
# Optional Docker-specific override if you need a full URL instead of DB_* values:
# DOCKER_DATABASE_URL=postgresql+asyncpg://edq:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/edq

# JWT token lifetimes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
# Local engineer testing works through the frontend at http://localhost:3000
# and the Vite dev server at http://localhost:5173.
# Replace these with your real domain(s) for shared or production deployments.
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173","http://127.0.0.1"]

# File storage
UPLOAD_DIR=./uploads
REPORT_DIR=./reports
# Set true only when the backend image was built with INSTALL_LIBREOFFICE=true.
# This lets PDF exports convert workbook-backed templates through LibreOffice.
EDQ_USE_LIBREOFFICE=false

# Frontend publish settings
EDQ_BIND_HOST=127.0.0.1
EDQ_PUBLIC_PORT=3000
DOMAIN=
LETSENCRYPT_EMAIL=
EDQ_USE_BUILTIN_TLS=false
EDQ_BACKEND_BIND_HOST=127.0.0.1
EDQ_BACKEND_PORT=8000
EDQ_TOOLS_BIND_HOST=127.0.0.1
EDQ_TOOLS_PORT=8001
EDQ_POSTGRES_BIND_HOST=127.0.0.1
EDQ_POSTGRES_PORT=55432

# Frontend build-time config
# Vite loads these from the repo root during local frontend dev because frontend/vite.config.ts
# points envDir at the parent directory. Docker builds can also override them with build args.
VITE_API_URL=/api
VITE_CLIENT_ERROR_ENDPOINT=/api/client-errors
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_SOURCEMAP=false

# Tools sidecar
# For Docker backend + Windows host scanner, use:
# TOOLS_SIDECAR_URL=http://host.docker.internal:8002
# EDQ_SCANNER_MODE=host
# EDQ_START_INTERNAL_TOOLS=false
TOOLS_SIDECAR_URL=http://127.0.0.1:8001
EDQ_SCANNER_MODE=auto
EDQ_START_INTERNAL_TOOLS=true
EDQ_TOOLS_RATE_LIMIT_PER_TARGET_PER_MINUTE=120
EDQ_FORCE_DOCKER_TCP_CONNECT_SCAN=true

# AI synopsis (optional)
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-4o

# Runtime
LOG_LEVEL=INFO
LOG_JSON=false
DEBUG=false
ALLOW_REGISTRATION=false

# Redis (optional, multi-instance deployments)
# REDIS_URL=redis://redis:6379/0

# OIDC / SSO (optional)
# OIDC_PROVIDER=google
# OIDC_CLIENT_ID=your-client-id.apps.googleusercontent.com
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_DISCOVERY_URL=
# OIDC_ALLOWED_DOMAINS=example.com

# Sentry (optional)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=edq@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# SENTRY_LOG_LEVEL=INFO
# SENTRY_EVENT_LEVEL=ERROR
# SENTRY_SEND_DEFAULT_PII=false

# Audit log retention
# AUDIT_LOG_RETENTION_DAYS=365
